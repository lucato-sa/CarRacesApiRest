# ============================================
# .env.docker - Variables para docker-compose
# ============================================
# Copiar este archivo a .env antes de ejecutar docker-compose
# O ejecutar: cp .env.docker .env

# 🌍 AMBIENTE
NODE_ENV=production

# 🎯 PUERTO DE LA API
PORT=3000

# 🎯 BACKEND (siempre postgres en Docker)
BACKEND=postgres

# 🗄️ POSTGRESQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=carracesapi
DB_USER=postgres
DB_PASSWORD=postgres
