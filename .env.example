# ============================================
# � CARRACESAPI - CONFIGURACIÓN DE AMBIENTE
# ============================================
# Copia este archivo a .env y completa con tus valores
# NUNCA commites .env con datos sensibles


# ============================================
# 🌍 AMBIENTE
# ============================================
# development | staging | production
NODE_ENV=development


# ============================================
# 🎯 BACKEND A USAR (para tests y desarrollo)
# ============================================
# memory   : En memoria (tests rápidos, sin BD)
# file     : Almacenamiento en archivo JSON
# postgres : PostgreSQL local o remoto
# supabase : Supabase (postgres hosted)
BACKEND=memory


# ============================================
# 🗄️ CONEXIÓN A POSTGRESQL (LOCAL)
# ============================================
# Solo necesario si BACKEND=postgres o NODE_ENV=development

# Host
# - Local: localhost o 127.0.0.1
# - Docker: nombre_del_servicio (ej: postgres)
# - Remoto: IP o DNS
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carracesapi

# Logging SQL (development only)
# true  : Ver queries SQL en consola
# false : Sin logs
DB_LOGGING=false


# ============================================
# ☁️ SUPABASE (Cloud PostgreSQL)
# ============================================
# Solo necesario si BACKEND=supabase

# URL del proyecto Supabase
# Formato: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Clave anónima (para cliente web)
# ⚠️ PÚBLICA: Solo para desarrollo/tests
SUPABASE_KEY_ANON=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (para backend)
# 🔐 PRIVADA: Usar solo en backend
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ============================================
# 🚀 SERVER
# ============================================
PORT=3000
HOST=0.0.0.0


# ============================================
# 📌 NOTAS DE USO
# ============================================
#
# DESARROLLO RÁPIDO (sin BD):
# BACKEND=memory
# npm run test -- -t "clubs"
#
# DESARROLLO CON PostgreSQL LOCAL:
# BACKEND=postgres
# DB_HOST=localhost
# npm run dev
#
# TESTS CON SUPABASE:
# BACKEND=supabase
# SUPABASE_URL=...
# SUPABASE_KEY=...
# npm run test:supabase
#
# PRODUCCIÓN:
# NODE_ENV=production
# BACKEND=supabase
# Usar secretos del CI/CD (NO en .env)
