# Test Environment Configuration - PostgreSQL Backend
# This uses actual PostgreSQL database for integration testing
# Make sure PostgreSQL is running and accessible

BACKEND=postgres
NODE_ENV=test

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carracesapi_test
DB_LOGGING=false

# SSL Configuration (set to true for Supabase)
DB_SSL=false
