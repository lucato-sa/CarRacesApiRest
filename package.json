{
  "name": "apicarraces",
  "version": "1.0.0",
  "description": "Api para la organización de carreras de coches",
  "license": "ISC",
  "author": "Carlos Torre",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "cross-env BACKEND=supabase NODE_ENV=production node --require dotenv/config dist/server.js",
    "start:dev": "cross-env BACKEND=supabase NODE_ENV=development node --require dotenv/config dist/server.js",
    "start:postgres": "cross-env BACKEND=postgres NODE_ENV=production node --require dotenv/config dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only --require dotenv/config src/server.ts",
    "test": "cross-env BACKEND=memory vitest --run",
    "test:memory": "cross-env BACKEND=memory vitest --run",
    "test:file": "cross-env BACKEND=file vitest --run",
    "test:postgres": "cross-env BACKEND=postgres vitest --run",
    "test:supabase": "cross-env BACKEND=supabase vitest --run",
    "test:all": "npm run test:memory && npm run test:file && npm run test:postgres && npm run test:supabase",
    "test:coverage": "cross-env BACKEND=memory vitest --coverage",
    "test:watch": "cross-env BACKEND=memory vitest --watch",
    "test:connection": "ts-node-dev --require dotenv/config test-connection.ts",
    "migrate:up": "psql $DATABASE_URL -f src/database/migrations/001-init-schema.sql",
    "migrate:down": "echo 'Manual migration rollback required'"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.5.1",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^2.0.16",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "express": "^4.18.2",
    "pg": "^8.18.0"
  }
}
